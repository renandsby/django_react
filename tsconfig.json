{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node", "jest", "express"],
    "jsx": "react-jsx",

    "strict": false,
    "allowJs": true,

    "esModuleInterop": true,
    "skipLibCheck": true,

    "noEmit": true
  },
  "include": ["src"]
}